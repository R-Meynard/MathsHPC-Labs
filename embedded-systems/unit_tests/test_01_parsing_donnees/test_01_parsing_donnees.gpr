with "gnatcoll_core.gpr";
with "aunit.gpr";

project Test_01_Parsing_Donnees is
   for Source_Dirs use ("src", "tests");
   for Object_Dir  use "obj";
   for Exec_Dir    use "bin";
   for Main        use ("main.adb", "test_runner.adb");

   package Builder is
      for Default_Switches ("Ada") use ("-g");  --  symboles de debug
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0");  --  pas d'optimisation
   end Compiler;
end Test_01_Parsing_Donnees;